APP_ENV=development
APP_URL=http://localhost:3000
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Qdrant: definir aqui segun donde corras la app.
# Local Acer (Qdrant en Docker local o tunel): http://127.0.0.1:6333
# EasyPanel (red interna n8n): http://n8n_qdrant:6333
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION_TEMPLATE=kb_<tenant_slug>_openai_1536

# Dejar vacio si Qdrant no usa API key
QDRANT_API_KEY=
