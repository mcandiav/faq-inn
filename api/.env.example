APP_ENV=development
APP_URL=http://localhost:3000
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# MariaDB embebido en el mismo contenedor api
MYSQL_DATABASE=dfaq
MYSQL_USER=dfaq
MYSQL_PASSWORD=dfaq
MYSQL_ROOT_PASSWORD=dfaq_root
DATABASE_URL=mysql://dfaq:dfaq@127.0.0.1:3306/dfaq

# Qdrant
# Local Acer: http://127.0.0.1:6333
# EasyPanel: http://n8n_qdrant:6333
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION_TEMPLATE=kb_<tenant_slug>_openai_1536
QDRANT_API_KEY=

# OpenAI embeddings (requerido para upsert/search)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSION=1536
