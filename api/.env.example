APP_ENV=development
APP_URL=http://localhost:3000
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# MariaDB externo (EasyPanel: bignotti_mariadb — misma instancia que planificador/cronometro)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=dfaq
DB_USER=dfaq_app
DB_PASSWORD=

# Solo para el primer deploy: password root de bignotti_mariadb (crea base + usuario si no existen)
DB_ADMIN_USER=root
DB_ADMIN_PASSWORD=

# Qdrant
# Local Acer: http://127.0.0.1:6333
# EasyPanel: http://n8n_qdrant:6333
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=

# Embeddings — proveedor por defecto: nvidia
EMBEDDING_PROVIDER=nvidia
EMBEDDING_DIMENSION=1024
QDRANT_COLLECTION_TEMPLATE=kb_<tenant_slug>_nvidia_1024

# NVIDIA (build.nvidia.com) — tier gratuito
NVIDIA_API_KEY=
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1
NVIDIA_EMBEDDING_MODEL=baai/bge-m3
NVIDIA_USE_INPUT_TYPE=false

# OpenAI (alternativa: EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Auth — admin global (se crea solo si no existe ninguno)
ADMIN_EMAIL=admin@at-once.cl
ADMIN_PASSWORD=
SESSION_SECRET=

# Token opcional para POST /api/unanswered desde n8n (Bearer o header X-N8N-Token)
N8N_ALLOWED_TOKEN=
