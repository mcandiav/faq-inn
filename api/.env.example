APP_ENV=development
APP_URL=http://localhost:3000
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Tenant de desarrollo (README V1.2)
TENANT=FAQ-INN
TENANT_SLUG=faq-inn
TENANT_DISPLAY_NAME=FAQ-INN
APP_TITLE=FAQ Inn FAQ-INN
APP_VERSION=1.1.0

# PostgreSQL propio FAQ Inn
# Local: 127.0.0.1:5432
# EasyPanel (red interna): n8n_faq-inn_postgres:5432
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=faq-inn
DB_USER=postgres
DB_PASSWORD=

# Qdrant
# Local Acer: http://127.0.0.1:6333
# EasyPanel: http://n8n_qdrant:6333
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=

# Embeddings — proveedor por defecto: ollama (red interna EasyPanel)
EMBEDDING_PROVIDER=ollama
EMBEDDING_DIMENSION=1024
QDRANT_COLLECTION_TEMPLATE=kb_<tenant_slug>_mxbai_1024

# Ollama (EasyPanel: n8n_ollama:11434)
OLLAMA_API_BASE=http://127.0.0.1:11434
OLLAMA_EMBEDDING_MODEL=mxbai-embed-large:latest

# NVIDIA (alternativa: EMBEDDING_PROVIDER=nvidia)
NVIDIA_API_KEY=
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1
NVIDIA_EMBEDDING_MODEL=baai/bge-m3
NVIDIA_USE_INPUT_TYPE=false

# OpenAI (alternativa: EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Auth — admin global (se crea solo si no existe ninguno)
ADMIN_EMAIL=admin@at-once.cl
ADMIN_PASSWORD=
SESSION_SECRET=

# Token opcional para POST /api/unanswered desde n8n (Bearer o header X-N8N-Token)
N8N_ALLOWED_TOKEN=

# Commit desplegado (opcional, para /health)
FAQ_INN_GIT_COMMIT=
