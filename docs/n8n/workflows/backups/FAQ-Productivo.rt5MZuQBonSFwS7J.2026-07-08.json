    {
      "id": "e5ddf180-56e4-4f1e-a6fa-a9c2ea83af38",
      "name": "Armar SPrompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1760,
        240
      ],
      "parameters": {
        "jsCode": "// \"Armar SPrompt\": resuelve los tokens neutros de las columnas del system\n// prompt (nodo \"Datos Tenant\") con datos del tenant y fechas segun timezone.\nconst tenant = $('Datos Tenant').first().json;\nconst sprompt = tenant.sprompt || {};\nconst tz = tenant.timezone || 'America/Santiago';\n\nfunction ymdInTz(date, timeZone) {\n  const parts = new Intl.DateTimeFormat('en-CA', {\n    timeZone,\n    year: 'numeric',\n    month: '2-digit',\n    day: '2-digit',\n  }).formatToParts(date);\n  const get = (type) => (parts.find((p) => p.type === type) || {}).value;\n  return `${get('year')}-${get('month')}-${get('day')}`;\n}\n\nfunction addDaysIso(iso, days) {\n  const d = new Date(`${iso}T12:00:00Z`);\n  d.setUTCDate(d.getUTCDate() + days);\n  return d.toISOString().slice(0, 10);\n}\n\nconst today = ymdInTz(new Date(), tz);\nconst tokens = {\n  tenant_display_name: tenant.tenant_display_name || tenant.tenant_name || '',\n  business_type: tenant.business_type || '',\n  initial_greeting: tenant.initial_greeting || '',\n  objetivo: tenant.objetivo || 'responder preguntas',\n  url: tenant.url || tenant.tenant_url || '',\n  validation_status: tenant.validation_status || 'pending',\n  agenda_validation_status: tenant.agenda_validation_status || 'pending',\n  date_format: tenant.date_format || '',\n  supports_rooms: String(tenant.supports_rooms === true),\n  supports_children: String(tenant.supports_children === true),\n  today,\n  today_plus_1: addDaysIso(today, 1),\n  today_plus_2: addDaysIso(today, 2),\n};\n\nfunction resolve(tpl) {\n  let out = String(tpl || '');\n  for (const key of Object.keys(tokens)) {\n    const re = new RegExp('\\\\{\\\\{\\\\s*' + key + '\\\\s*\\\\}\\\\}', 'g');\n    out = out.replace(re, tokens[key]);\n  }\n  return out;\n}\n\nconst sections = {\n  rol: resolve(sprompt.role_template),\n  limites: resolve(sprompt.limits_template),\n  tools: resolve(sprompt.tools_template),\n  interpretar_fecha: resolve(sprompt.date_interpretation_template),\n  data_collect: resolve(sprompt.data_collection_template),\n  links: resolve(sprompt.links_template),\n  // Admin-only por tenant. Vacio = no altera el prompt.\n  custom_sprompt: resolve(tenant.custom_sprompt || ''),\n  timezone: tz,\n  today,\n};\n\nreturn $input.all().map((item) => ({\n  json: { ...item.json, ...sections },\n}));\n"
      }
    },
